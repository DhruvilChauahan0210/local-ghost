{
  "name": "@dhruvil0210/local-ghost",
  "version": "1.2.2",
  "description": "Local Ghost — browser-native AI components for React. Natural language filtering, form auto-fill, and chart generation powered by WebGPU. Zero server. Zero API keys.",
  "keywords": [
    "local-ghost",
    "webgpu",
    "ai",
    "react",
    "data-grid",
    "transformers",
    "llm",
    "browser-ai",
    "zero-server",
    "privacy",
    "on-device"
  ],
  "homepage": "https://github.com/DhruvilChauahan0210/local-ghost",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DhruvilChauahan0210/local-ghost.git"
  },
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "recharts": "^2.0.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@webgpu/types": "^0.1.70",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vite-plugin-dts": "^4.0.0"
  }
}
